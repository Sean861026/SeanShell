<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SeanShell.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SeanShell.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="32" RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Developer workspace" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Live Windows context without replacing Explorer."
                        TextWrapping="Wrap" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    MinHeight="44"
                    AutomationProperties.HelpText="Open the keyboard-first application launcher."
                    Click="OnOpenLauncherClicked"
                    Content="Open Launcher"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CPU" />
                        <TextBlock x:Name="CpuValue" FontSize="24" FontWeight="SemiBold" Text="Sampling…" />
                        <ProgressBar x:Name="CpuProgress" Maximum="100" AutomationProperties.Name="CPU usage" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Memory" />
                        <TextBlock x:Name="MemoryValue" FontSize="24" FontWeight="SemiBold" Text="Loading…" />
                        <ProgressBar x:Name="MemoryProgress" Maximum="100" AutomationProperties.Name="Memory usage" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Open windows" />
                        <TextBlock x:Name="WindowCountValue" FontSize="24" FontWeight="SemiBold" Text="Loading…" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Shown in the dock" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Shell mode" />
                        <TextBlock x:Name="ModeText" FontSize="24" FontWeight="SemiBold" Text="Normal" />
                        <TextBlock x:Name="ProviderStatus" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Providers active" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Window dock" />
                        <TextBlock
                            Text="The lightweight dock lists normal application windows and switches focus without injection."
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="DockStatus"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Visible above the primary taskbar"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Launcher" />
                        <TextBlock Text="Search installed apps and safe system commands." TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="ShortcutStatus"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Keyboard shortcut: Alt + Space"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Spacing="16">
                <ToggleSwitch
                    x:Name="DockAutoHideToggle"
                    Header="Dock auto-hide"
                    OffContent="Dock remains expanded on every display"
                    OnContent="Dock collapses to a visible edge indicator"
                    Toggled="OnDockAutoHideToggled" />
                <ComboBox
                    x:Name="LauncherShortcutComboBox"
                    Width="260"
                    HorizontalAlignment="Left"
                    AutomationProperties.HelpText="Choose a supported global shortcut for opening the launcher."
                    Header="Launcher shortcut"
                    SelectionChanged="OnLauncherShortcutSelectionChanged">
                    <ComboBoxItem Content="Alt + Space" Tag="AltSpace" />
                    <ComboBoxItem Content="Ctrl + Alt + Space" Tag="ControlAltSpace" />
                    <ComboBoxItem Content="Ctrl + Shift + Space" Tag="ControlShiftSpace" />
                </ComboBox>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="A new shortcut is saved only after Windows confirms it is available."
                    TextWrapping="Wrap" />
                <Expander Header="Plugins">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <TextBlock
                            Text="Built-in plugins run behind capability checks and bounded operation timeouts."
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="PluginStatusSummary"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Loading plugin status"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="PluginEmptyState"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No built-in plugins are registered."
                            Visibility="Collapsed" />
                        <ItemsControl
                            x:Name="PluginDiagnosticsList"
                            AutomationProperties.Name="Plugin diagnostics">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:PluginDiagnosticViewModel">
                                    <Grid Padding="4,10" ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Identity}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Detail}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="4">
                                            <ToggleSwitch
                                                MinHeight="44"
                                                AutomationProperties.Name="{x:Bind ToggleName}"
                                                Header="Enabled"
                                                IsEnabled="{x:Bind CanToggle}"
                                                IsOn="{x:Bind IsEnabled}"
                                                Tag="{x:Bind Id}"
                                                Toggled="OnPluginEnabledToggled" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind State}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind CapabilityText}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
                <Expander Header="Gaming mode">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="GamingModeToggle"
                            Header="Manual gaming mode"
                            OffContent="Automatic detection controls the effective mode"
                            OnContent="Keep gaming mode active until manually disabled"
                            Toggled="OnGamingModeToggled" />
                        <ToggleSwitch
                            x:Name="AutomaticGamingModeToggle"
                            Header="Automatic game detection"
                            OffContent="Configured processes are not monitored"
                            OnContent="Enter gaming mode while a configured process is running"
                            Toggled="OnAutomaticGamingModeToggled" />
                        <TextBox
                            x:Name="GameProcessRulesTextBox"
                            MinHeight="88"
                            AcceptsReturn="True"
                            AutomationProperties.HelpText="Enter one game executable name per line. File paths and executable extensions are optional."
                            Header="Game process names"
                            PlaceholderText="eldenring.exe"
                            TextWrapping="Wrap" />
                        <Button
                            MinHeight="44"
                            HorizontalAlignment="Left"
                            Click="OnSaveGameRulesClicked"
                            Content="Save game rules" />
                        <TextBlock
                            x:Name="GamingDetectionStatus"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Automatic detection is off"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>
                <InfoBar
                    x:Name="SettingsStatus"
                    IsOpen="False"
                    IsClosable="True" />
                <InfoBar
                    x:Name="DashboardStatus"
                    IsOpen="True"
                    IsClosable="False"
                    Message="Explorer remains active; the dock only enumerates supported top-level windows."
                    Severity="Informational"
                    Title="Compatibility-first" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
